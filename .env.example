# Shared local defaults
# For iPhone access, point these at your private Tailscale hostname.
NEXT_PUBLIC_CONTROL_PLANE_URL=http://127.0.0.1:4000
NEXT_PUBLIC_JMCP_PUBLIC_WEB_URL=

# Control plane
# Use 0.0.0.0 when exposing JMCP over Tailscale or another private network.
JMCP_CONTROL_PLANE_HOST=0.0.0.0
JMCP_CONTROL_PLANE_PORT=4000
JMCP_CONTROL_PLANE_DATA_DIR=./data/control-plane
JMCP_CONTROL_PLANE_DB_PATH=./data/control-plane/jmcp.sqlite
JMCP_PUBLIC_WEB_URL=
JMCP_BRIDGE_SHARED_TOKEN=jmcp-local-bridge-token
JMCP_GITHUB_WEBHOOK_SECRET=jmcp-dev-github-secret
JMCP_AUTORUN_ENABLED=true
JMCP_NIGHTLY_START_HOUR=1
JMCP_NIGHTLY_END_HOUR=6

# Optional web push
# Generate VAPID keys before enabling these.
JMCP_WEB_PUSH_PUBLIC_KEY=
JMCP_WEB_PUSH_PRIVATE_KEY=
JMCP_WEB_PUSH_SUBJECT=mailto:operator@example.com
NEXT_PUBLIC_WEB_PUSH_PUBLIC_KEY=

# Telegram
# Rotate any previously exposed token before using it here.
JMCP_TELEGRAM_BOT_TOKEN=
JMCP_TELEGRAM_CHAT_ID=
JMCP_TELEGRAM_POLL_INTERVAL_MS=2000

# Optional xAI / Grok provider
# Use a rotated server-side key only. Never expose it to the browser or Telegram clients.
JMCP_XAI_API_KEY=
JMCP_XAI_MODEL=grok-4-0709
JMCP_XAI_BASE_URL=https://api.x.ai/v1

# Local voice
# These commands are optional. JMCP passes JMCP_VOICE_INPUT_PATH to the process.
# The transcribe command should print the transcript to stdout.
JMCP_VOICE_ASSET_DIR=./data/control-plane/voice
JMCP_VOICE_TRANSCRIBE_COMMAND=
JMCP_VOICE_TTS_COMMAND=

# Bridge
JMCP_BRIDGE_CONTROL_PLANE_URL=http://127.0.0.1:4000
JMCP_BRIDGE_NAME=Local Laptop Executor
JMCP_BRIDGE_HOST_LABEL=laptop
JMCP_BRIDGE_KIND=claude_code
JMCP_BRIDGE_POLL_INTERVAL_MS=1500
JMCP_BRIDGE_MAX_PARALLEL_RUNS=3
JMCP_BRIDGE_REPO_CACHE_ROOT=./data/local-bridge/repos
JMCP_BRIDGE_WORKTREE_ROOT=./data/local-bridge/worktrees
JMCP_BRIDGE_BUNDLE_ROOT=./data/local-bridge/bundles
JMCP_BRIDGE_CLAUDE_COMMAND=claude
JMCP_BRIDGE_GH_COMMAND=gh
JMCP_BRIDGE_DEFAULT_TEST_COMMANDS=npm test;npm run test;npm run check;npm run lint
JMCP_BRIDGE_PR_POLL_INTERVAL_MS=10000
JMCP_BRIDGE_PR_POLL_TIMEOUT_MS=1800000
