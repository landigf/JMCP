{
  "name": "jmcp",
  "version": "0.1.0",
  "private": true,
  "description": "Jarvis is My Co-Pilot",
  "license": "Apache-2.0",
  "packageManager": "npm@10.9.2",
  "engines": {
    "node": ">=24 <25"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*",
    "tooling/*"
  ],
  "scripts": {
    "lint": "biome check . && turbo run lint",
    "test": "turbo run test",
    "check": "npm run docs:check && turbo run check",
    "docs:check": "tsx tooling/repo-guardrails/src/cli.ts docs",
    "format": "biome format --write . && turbo run format",
    "quality:stub": "tsx tooling/repo-guardrails/src/cli.ts quality-stub",
    "dev:web": "npm --workspace @jmcp/operator-web run dev",
    "dev:control-plane": "npm --workspace @jmcp/control-plane run dev",
    "dev:bridge": "npm --workspace @jmcp/local-bridge run dev"
  },
  "devDependencies": {
    "@types/node": "^24.8.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/web-push": "^3.6.4",
    "@biomejs/biome": "^2.3.7",
    "turbo": "^2.5.8",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.1.1"
  }
}
